# HomeStack environment — copy to .env and adjust. NEVER commit the real .env.
# Phase 1.0 (walking-skeleton scaffold). Local-network only; no public exposure (Security §14).

# --- PostgreSQL ---
POSTGRES_DB=homestack
POSTGRES_USER=homestack
POSTGRES_PASSWORD=change-me-in-real-env
POSTGRES_HOST=homestack-postgres
POSTGRES_PORT=5432

# --- Django ---
# config.settings.{dev,prod,test}
DJANGO_SETTINGS_MODULE=config.settings.dev
# Generate a real one: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
# Includes the compose service name so the frontend dev proxy (changeOrigin) is accepted.
# On a real server you MUST add its hostname / LAN IP here, e.g. ...,moose-server,192.168.1.125
# In dev settings this also auto-adds the CSRF-trusted origin http://<host>:5173 for each entry,
# so adding your server IP here is what makes saving (POST/PATCH/DELETE) work from the browser.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,homestack-backend

# Django 4+ checks the browser Origin header on writes against CSRF_TRUSTED_ORIGINS. dev settings
# derive these from DJANGO_ALLOWED_HOSTS automatically; set this only to add extra origins
# (e.g. a reverse-proxy / https URL). Comma-separated scheme://host[:port].
# DJANGO_CSRF_TRUSTED_ORIGINS=https://homestack.example.com

# Secure cookies need HTTPS. Set to 0 for a plain-HTTP LAN deployment (prod settings only)
# or login will silently fail. Flip back to 1 once TLS/reverse-proxy is in place (M4).
DJANGO_SECURE_COOKIES=1

# --- Host port mappings (left side is the port on your machine) ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
DB_HOST_PORT=5432
